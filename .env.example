# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# A2A Hackathon Track — primary configuration
# See A2A.md and https://github.com/a2anet/a2a-hackathon-template
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Harness env API (started by `a2a-hack smoke` / `run` from a2a-hackathon repo)
ENV_API_URL=http://host.docker.internal:8090
CS_AGENT_URL=http://host.docker.internal:8090/cs-agent

# Per-service env API tokens (harness dev defaults — must match harness)
PERSONAL_ENV_API_TOKEN=dev-user-token
CS_ENV_API_TOKEN=dev-agent-token

# Model — gemini-3.5-flash is required for marked runs
MODEL=gemini-3.5-flash

# Vertex AI auth: API key from GCP (Vertex AI Agent Platform → API keys)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_API_KEY=

# Optional: same key for LangGraph A2UI demo (Track 2 — secondary in this repo)
# GEMINI_API_KEY=
# OFFLINE=1

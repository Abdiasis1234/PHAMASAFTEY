# PhamaSafety — environment template
# Copy to .env and fill in values.

# ─── Generative UI (Track 2) ────────────────────────────────────
AGENT_URL=http://localhost:8123
FIXED_AGENT_URL=http://localhost:8123/fixed
DYNAMIC_AGENT_URL=http://localhost:8123/dynamic

# Required for live LLM calls (/fixed, /dynamic, A2A agents).
# Vertex-style key (AQ.*) or AI Studio key both work with GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_LOCATION=us-central1

# Offline demo — fixed intake dashboard works WITHOUT a key
# OFFLINE=1

# ─── A2A agents (Track 1) ─────────────────────────────────────
MODEL=gemini-3.5-flash
PERSONAL_AGENT_PORT=9001
CS_AGENT_PORT=9002

# Standalone docker compose: personal agent uses http://cs-agent:9002 (default in compose)
# Harness smoke test: set CS_AGENT_URL=http://host.docker.internal:8090/cs-agent
CS_AGENT_URL=http://localhost:9002
REDIS_URL=redis://localhost:6379/0

# Harness env API (optional — grants user-side tools to agents)
ENV_API_URL=http://localhost:8090
PERSONAL_ENV_API_TOKEN=dev-user-token
CS_ENV_API_TOKEN=dev-agent-token

# Optional ADC (if org blocks API keys) — run scripts/setup-adc.ps1
# GOOGLE_CLOUD_PROJECT=your-gcp-project
